generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMINISTRATOR
  GATEKEEPER
  SUPERVISOR
}

enum ParticipantStatus {
  ACTIVE
  RETIRED
  SUSPENDED
}

enum Gender {
  MALE
  FEMALE
}

enum EventCategory {
  SURFING
  FITNESS
  SKATING
  BEACH_CLEAN_UP
  OTHER
}

enum ReportStatus {
  PENDING
  APPROVED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         UserRole @default(GATEKEEPER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdEvents    Event[]
  generatedReports MonthlyReport[]          @relation("GeneratedBy")
  approvedReports  MonthlyReport[]          @relation("ApprovedBy")
  changeRequests   ParticipantChangeRequest[]

  @@map("users")
}

model Participant {
  id               String            @id @default(uuid())
  tskId            String            @unique @map("tsk_id")
  registrationDate DateTime          @default(now()) @map("registration_date") @db.Date
  profilePicture   String?           @map("profile_picture")
  surname          String
  fullNames        String            @map("full_names")
  knownAs          String?           @map("known_as")
  gender           Gender
  idNumber         String            @unique @map("id_number")
  dateOfBirth      DateTime          @map("date_of_birth") @db.Date
  boltCardUrl      String?           @map("bolt_card_url")
  status           ParticipantStatus @default(ACTIVE)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  attendanceRecords    AttendanceRecord[]
  monthlyReportEntries MonthlyReportEntry[]
  changeRequests       ParticipantChangeRequest[]

  @@map("participants")
}

model ParticipantChangeRequest {
  id            String    @id @default(uuid())
  participantId String?   @map("participant_id")
  requestedBy   String    @map("requested_by")
  notes         String
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  participant     Participant? @relation(fields: [participantId], references: [id])
  requestedByUser User         @relation(fields: [requestedBy], references: [id])

  @@map("participant_change_requests")
}

model Event {
  id        String        @id @default(uuid())
  date      DateTime      @db.Date
  category  EventCategory
  note      String?
  createdBy String        @map("created_by")
  createdAt DateTime      @default(now()) @map("created_at")

  creator           User               @relation(fields: [createdBy], references: [id])
  attendanceRecords AttendanceRecord[]

  @@map("events")
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  eventId       String   @map("event_id")
  present       Boolean
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [participantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])

  @@unique([participantId, eventId])
  @@map("attendance_records")
}

model MonthlyReport {
  id          String       @id @default(uuid())
  month       String
  status      ReportStatus @default(PENDING)
  generatedAt DateTime     @default(now()) @map("generated_at")
  generatedBy String       @map("generated_by")
  approvedAt  DateTime?    @map("approved_at")
  approvedBy  String?      @map("approved_by")

  generator User               @relation("GeneratedBy", fields: [generatedBy], references: [id])
  approver  User?              @relation("ApprovedBy", fields: [approvedBy], references: [id])
  entries   MonthlyReportEntry[]

  @@unique([month])
  @@map("monthly_reports")
}

model MonthlyReportEntry {
  id            String   @id @default(uuid())
  reportId      String   @map("report_id")
  participantId String   @map("participant_id")
  totalEvents   Int      @map("total_events")
  attended      Int
  percentage    Decimal  @db.Decimal(5, 2)
  rewardSats    Int      @map("reward_sats")
  payoutStatus  String   @default("pending") @map("payout_status")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  report      MonthlyReport @relation(fields: [reportId], references: [id])
  participant Participant   @relation(fields: [participantId], references: [id])

  @@unique([reportId, participantId])
  @@map("monthly_report_entries")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ParticipantStatus {
  ACTIVE
  RETIRED
}

enum CertificationType {
  SAFEGUARDING
  LIFESAVING
  SURFCOACHING
}

enum Gender {
  MALE
  FEMALE
}

enum EventCategory {
  SURFING
  FITNESS
  SKATING
  BEACH_CLEAN_UP
  OTHER
}

enum ReportStatus {
  PENDING
  APPROVED
}

enum PaymentMethod {
  BOLT_CARD
  LIGHTNING_ADDRESS
}

enum TskGroup {
  TURTLES
  SEALS
  DOLPHINS
  SHARKS
  FREE_SURFERS
}

model Participant {
  id               String            @id @default(uuid())
  tskId            String            @unique @map("tsk_id")
  registrationDate DateTime          @default(now()) @map("registration_date")
  profilePicture   String?           @map("profile_picture")
  surname          String
  fullNames        String            @map("full_names")
  knownAs          String?           @map("known_as")
  gender           Gender
  idNumber         String            @unique @map("id_number")
  dateOfBirth      DateTime          @map("date_of_birth")
  boltUserId       String?           @map("bolt_user_id")
  isAssistantCoach    Boolean   @default(false) @map("is_assistant_coach")
  assistantCoachSince DateTime? @map("assistant_coach_since")
  ethnicity        String?
  language         String?
  school           String?
  grade            String?
  guardian         String?
  guardianId       String?           @map("guardian_id")
  guardianRelationship String?       @map("guardian_relationship")
  address          String?
  contact1         String?           @map("contact_1")
  contact2         String?           @map("contact_2")
  housingType      String?           @map("housing_type")
  idDocumentUrl        String?       @map("id_document_url")
  idDocumentUploadedAt DateTime?     @map("id_document_uploaded_at")
  indemnityFormUrl     String?       @map("indemnity_form_url")
  indemnityUploadedAt  DateTime?     @map("indemnity_uploaded_at")
  tskStatus        String?           @map("tsk_status")
  tskStatusUpdatedAt DateTime?       @map("tsk_status_updated_at")
  weightKg            Float?    @map("weight_kg")
  weightUpdatedAt     DateTime? @map("weight_updated_at")
  heightCm            Float?    @map("height_cm")
  heightUpdatedAt     DateTime? @map("height_updated_at")
  tshirtSize          String?   @map("tshirt_size")
  tshirtSizeUpdatedAt DateTime? @map("tshirt_size_updated_at")
  shoeSize            String?   @map("shoe_size")
  shoeSizeUpdatedAt   DateTime? @map("shoe_size_updated_at")
  wetsuiteSize        String?   @map("wetsuit_size")
  wetsuiteUpdatedAt   DateTime? @map("wetsuit_updated_at")
  stance           String?
  notes            String?
  paymentMethod    PaymentMethod     @default(BOLT_CARD) @map("payment_method")
  lightningAddress String?           @map("lightning_address")
  measurementsUpdatedAt DateTime?     @map("measurements_updated_at")
  status           ParticipantStatus @default(ACTIVE)
  retiredAt        DateTime?         @map("retired_at")
  retiredReason    String?           @map("retired_reason")
  retiredReasonOther String?         @map("retired_reason_other")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  attendanceRecords     AttendanceRecord[]
  monthlyReportEntries  MonthlyReportEntry[]
  changeRequests        ParticipantChangeRequest[]
  certifications        Certification[]
  performanceEvents     PerformanceEvent[]
  schoolReports         SchoolReport[]
  tskReviews            TskReview[]
  tskLevelHistory       TskLevelHistory[]
  academicPayoutEntries AcademicPayoutEntry[]
  specialPayoutEntries  SpecialPayoutEntry[]
  pendingChanges        PendingParticipantChange[]

  @@map("participants")
}

model ParticipantChangeRequest {
  id            String    @id @default(uuid())
  participantId String?   @map("participant_id")
  requestedBy   String    @map("requested_by")
  notes         String
  status        String    @default("pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  participant Participant? @relation(fields: [participantId], references: [id])

  @@map("participant_change_requests")
}

model PerformanceEvent {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  eventDate     DateTime @map("event_date")
  eventName     String   @map("event_name")
  location      String?
  division      String?
  result        String
  verifyUrl     String?  @map("verify_url")
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("performance_events")
}

model Certification {
  id            String            @id @default(uuid())
  participantId String            @map("participant_id")
  type          CertificationType
  fileUrl       String            @map("file_url")
  uploadedAt    DateTime          @default(now()) @map("uploaded_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model Event {
  id        String        @id @default(uuid())
  date      DateTime
  category  EventCategory
  group     TskGroup?
  note      String?
  createdBy String        @map("created_by")
  createdAt DateTime      @default(now()) @map("created_at")

  attendanceRecords AttendanceRecord[]

  @@map("events")
}

model AttendanceRecord {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  eventId       String   @map("event_id")
  present       Boolean
  onTour        Boolean  @default(false) @map("on_tour")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [participantId], references: [id])
  event       Event       @relation(fields: [eventId], references: [id])

  @@unique([participantId, eventId])
  @@map("attendance_records")
}

model SchoolReport {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  year          Int
  term1Result   Float?   @map("term1_result")
  term1FileUrl  String?  @map("term1_file_url")
  term2Result   Float?   @map("term2_result")
  term2FileUrl  String?  @map("term2_file_url")
  term3Result   Float?   @map("term3_result")
  term3FileUrl  String?  @map("term3_file_url")
  term4Result   Float?   @map("term4_result")
  term4FileUrl  String?  @map("term4_file_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, year])
  @@map("school_reports")
}

model TskReview {
  id            String   @id @default(uuid())
  participantId String   @map("participant_id")
  reviewDate    DateTime @map("review_date")
  documentUrl   String?  @map("document_url")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("tsk_reviews")
}

model MonthlyReport {
  id              String       @id @default(uuid())
  month           String
  group           TskGroup?
  status          ReportStatus @default(PENDING)
  generatedAt     DateTime     @default(now()) @map("generated_at")
  generatedBy     String       @map("generated_by")
  approvedAt      DateTime?    @map("approved_at")
  approvedBy      String?      @map("approved_by")
  paymentRequest  String?      @map("payment_request")
  paymentHash     String?      @map("payment_hash")
  payoutStatus    String       @default("unpaid") @map("payout_status")
  totalPayoutSats Int          @default(0) @map("total_payout_sats")
  batchId         Int?         @map("batch_id")

  entries MonthlyReportEntry[]

  @@unique([month, group])
  @@map("monthly_reports")
}

model MonthlyReportEntry {
  id            String   @id @default(uuid())
  reportId      String   @map("report_id")
  participantId String   @map("participant_id")
  totalEvents   Int      @map("total_events")
  attended      Int
  percentage    Float
  rewardSats    Int      @map("reward_sats")
  payoutStatus  String   @default("pending") @map("payout_status")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  report      MonthlyReport @relation(fields: [reportId], references: [id])
  participant Participant   @relation(fields: [participantId], references: [id])

  @@unique([reportId, participantId])
  @@map("monthly_report_entries")
}

model AcademicPayout {
  id              String       @id @default(uuid())
  year            Int
  term            Int
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at")
  createdBy       String       @map("created_by")
  approvedAt      DateTime?    @map("approved_at")
  approvedBy      String?      @map("approved_by")
  paymentRequest  String?      @map("payment_request")
  paymentHash     String?      @map("payment_hash")
  payoutStatus    String       @default("unpaid") @map("payout_status")
  totalPayoutSats Int          @default(0) @map("total_payout_sats")
  batchId         Int?         @map("batch_id")
  entries         AcademicPayoutEntry[]

  @@unique([year, term])
  @@map("academic_payouts")
}

model AcademicPayoutEntry {
  id            String         @id @default(uuid())
  payoutId      String         @map("payout_id")
  participantId String         @map("participant_id")
  gradePercent  Float          @map("grade_percent")
  rewardSats    Int            @map("reward_sats")
  payoutStatus  String         @default("pending") @map("payout_status")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  payout        AcademicPayout @relation(fields: [payoutId], references: [id])
  participant   Participant    @relation(fields: [participantId], references: [id])

  @@unique([payoutId, participantId])
  @@map("academic_payout_entries")
}

model SpecialPayout {
  id              String       @id @default(uuid())
  title           String
  status          ReportStatus @default(PENDING)
  createdAt       DateTime     @default(now()) @map("created_at")
  createdBy       String       @map("created_by")
  approvedAt      DateTime?    @map("approved_at")
  approvedBy      String?      @map("approved_by")
  paymentRequest  String?      @map("payment_request")
  paymentHash     String?      @map("payment_hash")
  payoutStatus    String       @default("unpaid") @map("payout_status")
  totalPayoutSats Int          @default(0) @map("total_payout_sats")
  batchId         Int?         @map("batch_id")
  entries         SpecialPayoutEntry[]

  @@map("special_payouts")
}

model SpecialPayoutEntry {
  id            String        @id @default(uuid())
  payoutId      String        @map("payout_id")
  participantId String        @map("participant_id")
  amountSats    Int           @map("amount_sats")
  note          String?
  payoutStatus  String        @default("pending") @map("payout_status")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  payout        SpecialPayout @relation(fields: [payoutId], references: [id])
  participant   Participant   @relation(fields: [participantId], references: [id])

  @@unique([payoutId, participantId])
  @@map("special_payout_entries")
}

model TskLevelHistory {
  id            String      @id @default(uuid())
  participantId String      @map("participant_id")
  level         String
  changedAt     DateTime    @map("changed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("tsk_level_history")
}

model RewardSettings {
  id            String   @id @default(uuid())
  minSats       Int      @map("min_sats")
  maxSats       Int      @map("max_sats")
  effectiveFrom DateTime @map("effective_from")
  createdAt     DateTime @default(now()) @map("created_at")
  createdBy     String   @map("created_by")

  @@map("reward_settings")
}

model PendingParticipantChange {
  id            String    @id @default(uuid())
  participantId String    @map("participant_id")
  field         String    // "tskStatus" | "isAssistantCoach"
  oldValue      String?   @map("old_value")
  newValue      String?   @map("new_value")
  effectiveFrom DateTime  @map("effective_from")
  appliedAt     DateTime? @map("applied_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @map("created_by")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, field])
  @@map("pending_participant_changes")
}

